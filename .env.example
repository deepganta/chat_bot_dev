# Required: OpenAI API key used by embeddings, judge, and response generation.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Fernet key for encrypting conversation transcripts at rest.
CONVERSATION_KEY=replace-with-fernet-key

# Optional: Password for Streamlit UI login gate (auth disabled if blank).
CHATBOT_PASSWORD=replace-with-ui-password

# Optional: Custom guardrail YAML path; defaults are used when unset.
GUARDRAIL_CONFIG_PATH=

# Optional: Corpus config path; defaults to Configs/corpus.yaml when unset.
CORPUS_CONFIG_PATH=Configs/corpus.yaml
